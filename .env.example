# =============================================================================
# regs-checker environment configuration
# Copy to .env and fill in your values:  cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Database — application data (sources, documents, extractions)
# ---------------------------------------------------------------------------
# Local development (Docker postgres — default if unset):
# REGS_DATABASE_URL=postgresql://regs:regs@localhost:5432/regs_checker
#
# Supabase production:
# REGS_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Supabase — Regs Checker pipeline DB (wjxlimjpaijdogyrqtxc, us-east-1)
# Used as extraction source by sync_extractions.py
# ---------------------------------------------------------------------------
# REGS_SUPABASE_URL=postgresql://postgres.wjxlimjpaijdogyrqtxc:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Supabase — Policy Navigator product DB (aaxxunfarlhmydvohsrm, us-east-2)
# Used as sync target by sync_extractions.py and monitored by sync_monitor.py
# ---------------------------------------------------------------------------
# REGS_POLICY_NAVIGATOR_URL=postgresql://postgres.aaxxunfarlhmydvohsrm:<password>@aws-0-us-east-2.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Object Storage (S3 / MinIO)
# ---------------------------------------------------------------------------
# REGS_S3_ENDPOINT_URL=http://localhost:9000
# REGS_S3_ACCESS_KEY=minioadmin
# REGS_S3_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# Anthropic API — required when extraction_provider=anthropic
# ---------------------------------------------------------------------------
# REGS_ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# LLM Provider Routing
# ---------------------------------------------------------------------------
# Global default provider: "anthropic" or "local"
# REGS_LLM_PROVIDER=anthropic
#
# Per-task overrides (take precedence over the global default):
# REGS_DISCOVERY_PROVIDER=local
# REGS_EXTRACTION_PROVIDER=anthropic
#
# Anthropic extraction model (used when extraction_provider=anthropic):
# REGS_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Local LLM — OpenAI-compatible API (Ollama, llama.cpp, vLLM, etc.)
# Required when discovery_provider=local or extraction_provider=local
# ---------------------------------------------------------------------------
# REGS_LOCAL_LLM_URL=http://localhost:11434
# REGS_LOCAL_LLM_MODEL=llama-3.1-8b
#
# Per-agent model overrides are set in code (class attributes):
#   ObligationAgent, DefinitionActorAgent, ThresholdExceptionAgent → qwen2.5:32b-instruct-q4_K_M
#   AmbiguityAgent → deepseek-r1:32b

# ---------------------------------------------------------------------------
# Debug mode
# ---------------------------------------------------------------------------
# REGS_DEBUG=true
