# =============================================================================
# regs-checker environment configuration
# Copy to .env and fill in your values:  cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Database — application data (sources, documents, extractions)
# ---------------------------------------------------------------------------
# Local development (Docker postgres — default if unset):
# REGS_DATABASE_URL=postgresql://regs:regs@localhost:5432/regs_checker
#
# Supabase production:
# REGS_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Object Storage (S3 / MinIO)
# ---------------------------------------------------------------------------
# REGS_S3_ENDPOINT_URL=http://localhost:9000
# REGS_S3_ACCESS_KEY=minioadmin
# REGS_S3_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# Anthropic API — required for extraction agents
# ---------------------------------------------------------------------------
# REGS_ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Debug mode
# ---------------------------------------------------------------------------
# REGS_DEBUG=true
